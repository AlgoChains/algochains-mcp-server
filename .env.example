# ═══════════════════════════════════════════════════════════════
# AlgoChains MCP Server v3 — Environment Configuration
# Copy to .env and fill in your credentials
# ═══════════════════════════════════════════════════════════════

# ── AlgoChains Platform ────────────────────────────────────────
# Get your API key from https://algochains.ai/dashboard
ALGOCHAINS_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Alpaca (Direct API) ──────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Interactive Brokers (TWS must be running) ────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ── Oanda (Forex) ───────────────────────────────────────────
OANDA_ACCOUNT_ID=
OANDA_ACCESS_TOKEN=
OANDA_ENVIRONMENT=practice

# ── TradersPost.io (Webhook Router) ─────────────────────────
# Routes to: Schwab, Robinhood, Tastytrade, TradeStation,
#            Tradier, Coinbase, Kraken, Bitget, ByBit
TRADERSPOST_WEBHOOK_URL=
TRADERSPOST_API_KEY=

# ── QuantConnect (LEAN Algorithm Platform) ───────────────────
QUANTCONNECT_USER_ID=
QUANTCONNECT_API_TOKEN=

# ── AlgoChains Marketplace ───────────────────────────────────
ALGOCHAINS_DJANGO_URL=https://algochains.ai
LISTING_API_KEY=
METRICS_INGEST_API_KEY=
ALGOCHAINS_CREATOR_USERNAME=tyler
