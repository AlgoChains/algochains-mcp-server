# ═══════════════════════════════════════════════════════════════
# AlgoChains MCP Server v20 — Environment Configuration
# Copy to .env and fill in your credentials
# Run "python scripts/startup_health_check.py" to verify setup
#
# Tier structure:
#   Free      → Yahoo Finance data, backtest templates
#   $49/mo    → Polygon, Alpha Vantage, full strategy builder
#   $199/mo   → Builder SDK, Supabase data warehouse, marketplace submission
#   $499/mo   → Institutional execution, FIX gateway, white-label
# ═══════════════════════════════════════════════════════════════

# ── AlgoChains Platform ─────────────────────────────────────────
# Get your API key from https://algochains.ai/dashboard
ALGOCHAINS_API_KEY=
ALGOCHAINS_DJANGO_URL=https://algochains.ai

# ── Builder SDK ($199/mo tier) ───────────────────────────────────
# Enables: Supabase data warehouse, marketplace submission, paper trading monitor
# Get from: https://algochains.ai/dashboard/builder
ALGOCHAINS_BUILDER_KEY=

# ── Signal HMAC Security (Django trade propagation — Roo architecture) ──
# REQUIRED for paper trading and live mode signal propagation.
# Minimum 32 characters. Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# This secret signs every signal so Django can verify authenticity.
ALGOCHAINS_SIGNAL_SECRET=
# Full ingest URL (HTTPS). MCP tool: propagate_trade_signal
ALGOCHAINS_SIGNAL_URL=
# Legacy aliases (also accepted by trade_propagation.py and examples/trade_propagation/send_signal.py)
SIGNAL_SECRET=
SIGNAL_URL=

# ── AlgoChains Marketplace API Keys ──────────────────────────────
# For publishing and updating strategy listings.
LISTING_API_KEY=
METRICS_INGEST_API_KEY=
# CI / production: require both keys in startup_health_check.py
# ALGOCHAINS_MARKETPLACE_STRICT=1
# Local dev only (disables fail-fast in MarketplaceBridge — do not use in prod):
# ALGOCHAINS_SKIP_MARKETPLACE_KEY_CHECK=1

# ── Supabase (Marketplace DB + Platform Tables) ───────────────────
# Main project: <your-supabase-project-ref> (marketplace listings, subscriptions)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=          # Service role key for server-side writes (tickets, oauth tokens, analytics)
SUPABASE_SERVICE_ROLE_KEY=     # Alias used by waitlist.py; set to the same value as SUPABASE_SERVICE_KEY
SUPABASE_RESET_REDIRECT_URL=https://algochains.ai/auth/reset-password

# ── Email (Resend) ────────────────────────────────────────────────
# https://resend.com — used for support tickets, waitlist, verification codes
RESEND_API_KEY=
SUPPORT_FROM_EMAIL=support@algochains.ai
WAITLIST_FROM_EMAIL=waitlist@algochains.ai
VERIFICATION_FROM_EMAIL=noreply@algochains.ai
SUPPORT_EMAIL=support@algochains.ai

# ── SMS (Twilio) — optional, enables SMS verification codes ───────
# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=             # E.164 format: +15551234567

# ── Notion Integration — optional, syncs support tickets ─────────
NOTION_API_KEY=
NOTION_SUPPORT_DB_ID=           # Notion database ID for support tickets

# ── Charles Schwab (TD Ameritrade successor) ──────────────────────
# https://developer.schwab.com/products/trader-api--individual-
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_ACCESS_TOKEN=            # Set after completing OAuth flow
SCHWAB_ACCOUNT_HASH=            # Auto-populated on first connect
SCHWAB_PAPER=false

# ── Kalshi (prediction markets — RSA signed REST) ────────────────
# https://docs.kalshi.com/getting_started/api_keys
KALSHI_ACCESS_KEY=
KALSHI_PRIVATE_KEY_PATH=       # Path to PEM private key (chmod 600)
# Or inline PEM for containers (avoid in production):
# KALSHI_PRIVATE_KEY_PEM=
# Production default: https://api.elections.kalshi.com — override for demo:
# KALSHI_API_HOST=https://demo-api.kalshi.co

# ── Polymarket CLOB (optional — for authenticated trading only) ───
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# ── OAuth General Settings ────────────────────────────────────────
ALGOCHAINS_OAUTH_REDIRECT_URI=https://algochains.ai/oauth/callback

# ── HTTP Transport Security ───────────────────────────────────────
# Bearer token for the HTTP/SSE transport (algochains-mcp-http).
# Set this to secure remote agent connections.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ALGOCHAINS_HTTP_TRANSPORT_SECRET=
# Allowed CORS origins for HTTP transport (comma-separated, * = all)
ALGOCHAINS_HTTP_CORS_ORIGINS=*

# ── Account Protection Preset ────────────────────────────────────
# Options: conservative | moderate | aggressive
# conservative: VIX>25 kill, daily loss $200, drawdown 8%
# moderate:     VIX>35 kill, daily loss $500, drawdown 15%  ← recommended
# aggressive:   VIX>45 kill, daily loss $2000, drawdown 25%
ALGOCHAINS_PROTECTION_PRESET=moderate

# ═══════════════════════════════════════════════════════════════
# BROKERS — Fill in at least one for live trading
# ═══════════════════════════════════════════════════════════════

# ── Tradovate (Futures — MNQ, CL, MES, NQ, ES) ────────────────
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_CID=
TRADOVATE_SECRET=
TRADOVATE_DEVICE_ID=
# Environment: demo | live
TRADOVATE_ENVIRONMENT=demo

# ── Alpaca (Equities — stocks, ETFs) ─────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# https://paper-api.alpaca.markets (paper) | https://api.alpaca.markets (live)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Interactive Brokers (TWS must be running) ────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ── OANDA (Forex) ────────────────────────────────────────────
OANDA_ACCOUNT_ID=
OANDA_ACCESS_TOKEN=
# practice | live
OANDA_ENVIRONMENT=practice

# ── TradersPost.io (Webhook Meta-Router) ─────────────────────
# Routes signals to: Schwab, Robinhood, Tastytrade, TradeStation,
#                    Tradier, Coinbase, Kraken, Bitget, ByBit
TRADERSPOST_WEBHOOK_URL=
TRADERSPOST_API_KEY=

# ── QuantConnect (LEAN Algorithm Platform) ───────────────────
QUANTCONNECT_USER_ID=
QUANTCONNECT_API_TOKEN=

# ═══════════════════════════════════════════════════════════════
# DATA PROVIDERS — Pick any you want (Yahoo Finance = free, no key)
# ═══════════════════════════════════════════════════════════════

# ── Polygon.io (Stocks, Options, Forex, Crypto) ─────────────────
# Free: 5/min | $29/mo: unlimited | https://polygon.io
POLYGON_API_KEY=

# ── Alpha Vantage (Stocks, Forex, Crypto, 110+ technicals) ─────
# Free: 25/day | $49.99/mo: 75/min | https://alphavantage.co
ALPHA_VANTAGE_API_KEY=

# ── Finnhub (Quotes, news, earnings, insider trades, SEC) ───────
# Free: 60/min | $49/mo: 300/min | https://finnhub.io
FINNHUB_API_KEY=

# ── Twelve Data (800+ exchanges, stocks/forex/crypto) ───────────
# Free: 800 credits/day | $29/mo | https://twelvedata.com
TWELVE_DATA_API_KEY=

# ── Databento (Tick Data / L2 Book — institutional) ─────────────
# Professional-grade tick data, L2 order book, futures
# No free tier | https://databento.com
DATABENTO_API_KEY=

# ── Unusual Whales (Options Flow / Dark Pool) ────────────────────
# Options flow, dark pool prints, GEX, DIX
# $57/mo | https://unusualwhales.com
UNUSUAL_WHALES_API_KEY=

# ── Intrinio (Fundamentals / Options Data) ───────────────────────
# Company fundamentals, options chains, institutional holdings
# Free trial | https://intrinio.com
INTRINIO_API_KEY=

# ── Nasdaq Data Link / Quandl (Economic / Macro) ────────────────
QUANDL_API_KEY=

# ── OpenBB (Aggregated Multi-Source) ─────────────────────────────
OPENBB_PAT=

# ═══════════════════════════════════════════════════════════════
# NOTIFICATIONS (Optional — get alerts on your phone/Slack)
# ═══════════════════════════════════════════════════════════════

# ── Slack ──────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=                       # Your Slack channel ID (e.g. C0XXXXXXXXX)
SLACK_CHANNEL_BOT_CHANGELOG=            # #tradovate-futures-bot-changelog channel ID
SLACK_CHANNEL_INCIDENTS=               # #incident-response channel ID
OWNER_SLACK_USER_ID=                    # Owner's Slack user ID for destructive-action verification
WAITLIST_NOTIFY_SECRET=        # Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
SLACK_WEBHOOK_URL=
# For signal routing alerts to #tradovate-futures-bot-changelog
SLACK_CHANNEL_SIGNAL_ALERTS=#tradovate-futures-bot-changelog

# ── Discord ────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Firebase Cloud Messaging (Mobile Push) ─────────────────────
FCM_SERVER_KEY=

# ── Email (SendGrid / Resend) ──────────────────────────────────
EMAIL_API_KEY=

# ═══════════════════════════════════════════════════════════════
# ADVANCED — Only needed for institutional/V14+ features
# ═══════════════════════════════════════════════════════════════

# ── OpenAI (LLM Strategy Generator, Intent Engine) ─────────────
OPENAI_API_KEY=

# ── Anthropic (Claude for strategy analysis) ───────────────────
ANTHROPIC_API_KEY=

# ── Onyx Knowledge Base ─────────────────────────────────────────
# Self-hosted RAG over AlgoChains docs, strategies, Slack archives.
# Point this at your own Onyx host (localhost or a private VPN address).
ONYX_API_KEY=
ONYX_API_URL=http://localhost:8080

# Optional: private compute node for heavy ML jobs (dispatch_tower_job).
# Set to your own VPN/Tailscale host; leave blank to keep all compute local.
ALGOCHAINS_TOWER_HOST=

# ── PostgreSQL (Moltbook debate engine) ─────────────────────────
MOLTBOOK_DB_URL=postgresql://algochains:@127.0.0.1:5434/moltbook

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6380

# ── AWS (S3 tick data backup) ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── BYOK Tool Mode ───────────────────────────────────────────────
# smart (default) = 25 Tier-1 tools exposed
# full = all 275+ tools exposed (use with Claude Code, not Cursor)
ALGOCHAINS_TOOL_MODE=smart
