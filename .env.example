# ═══════════════════════════════════════════════════════════════
# AlgoChains MCP Server v7 — Environment Configuration
# Copy to .env and fill in your credentials
# Only fill in what you need — everything is optional except
# at least one broker for trading, or one data provider for data.
# TIP: Run "discover_keys" to auto-detect keys you already have!
# ═══════════════════════════════════════════════════════════════

# ── AlgoChains Platform ────────────────────────────────────────
# Get your API key from https://algochains.ai/dashboard
ALGOCHAINS_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Alpaca (Direct API) ──────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Interactive Brokers (TWS must be running) ────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ── Oanda (Forex) ───────────────────────────────────────────
OANDA_ACCOUNT_ID=
OANDA_ACCESS_TOKEN=
OANDA_ENVIRONMENT=practice

# ── TradersPost.io (Webhook Router) ─────────────────────────
# Routes to: Schwab, Robinhood, Tastytrade, TradeStation,
#            Tradier, Coinbase, Kraken, Bitget, ByBit
TRADERSPOST_WEBHOOK_URL=
TRADERSPOST_API_KEY=

# ── QuantConnect (LEAN Algorithm Platform) ───────────────────
QUANTCONNECT_USER_ID=
QUANTCONNECT_API_TOKEN=

# ── AlgoChains Marketplace ───────────────────────────────────
ALGOCHAINS_DJANGO_URL=https://algochains.ai
LISTING_API_KEY=
METRICS_INGEST_API_KEY=
ALGOCHAINS_CREATOR_USERNAME=tyler

# ═══════════════════════════════════════════════════════════════
# DATA PROVIDERS (Optional — pick any you want)
# Yahoo Finance works without a key. All others need one.
# ═══════════════════════════════════════════════════════════════

# ── Polygon.io ─────────────────────────────────────────────────
# Stocks, Options, Forex, Crypto — real-time + historical
# Free: 5/min | $29/mo: unlimited | https://polygon.io
POLYGON_API_KEY=

# ── Alpha Vantage ──────────────────────────────────────────────
# Stocks, Forex, Crypto, 110+ technicals built-in
# Free: 25/day | $49.99/mo: 75/min | https://alphavantage.co
ALPHA_VANTAGE_API_KEY=

# ── Finnhub ────────────────────────────────────────────────────
# Real-time quotes, news, earnings, insider trades, SEC filings
# Free: 60/min | $49/mo: 300/min | https://finnhub.io
FINNHUB_API_KEY=

# ── Twelve Data ────────────────────────────────────────────────
# 800+ exchanges, stocks/forex/crypto, WebSocket on paid
# Free: 800 credits/day | $29/mo | https://twelvedata.com
TWELVE_DATA_API_KEY=

# ═══════════════════════════════════════════════════════════════
# NOTIFICATIONS (V6 — Optional)
# ═══════════════════════════════════════════════════════════════

# ── Slack ──────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Discord ────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Firebase Cloud Messaging (Mobile Push) ─────────────────────
FCM_SERVER_KEY=

# ── Email (SendGrid / Resend) ──────────────────────────────────
EMAIL_API_KEY=

# ═══════════════════════════════════════════════════════════════
# V7 BYOK — Additional Data Providers (Auto-discovered)
# These providers are auto-detected by the BYOK Key Orchestrator.
# Run "discover_keys" to see what you already have configured.
# ═══════════════════════════════════════════════════════════════

# ── Databento (Tick Data / L2 Book) ──────────────────────────────
# Professional-grade tick data, L2 order book, futures
# No free tier | https://databento.com
DATABENTO_API_KEY=

# ── Unusual Whales (Options Flow / Dark Pool) ────────────────────
# Options flow, dark pool prints, GEX, DIX
# No free tier | $57/mo | https://unusualwhales.com
UNUSUAL_WHALES_API_KEY=

# ── Intrinio (Fundamentals / Options Data) ───────────────────────
# Company fundamentals, options chains, institutional holdings
# Free trial | https://intrinio.com
INTRINIO_API_KEY=

# ── Nasdaq Data Link / Quandl (Economic / Macro) ────────────────
# Economic indicators, macro data, alternative data
# Free: 50/day | https://data.nasdaq.com
QUANDL_API_KEY=

# ── OpenBB (Aggregated Multi-Source) ─────────────────────────────
# Aggregated financial data across multiple sources
# Free tier | https://openbb.co
OPENBB_PAT=
