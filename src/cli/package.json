{
  "name": "@algochains/cli",
  "version": "22.5.0",
  "description": "AlgoChains interactive CLI — REPL, daemon, trust ladder, and full tool access",
  "type": "module",
  "bin": {
    "algochains": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "node --import tsx --test test/*.test.mjs",
    "compile:linux": "bun build src/index.ts --compile --outfile ../../dist/algochains-linux-x64  --target bun-linux-x64",
    "compile:darwin": "bun build src/index.ts --compile --outfile ../../dist/algochains-darwin-arm64 --target bun-darwin-arm64",
    "compile:win": "bun build src/index.ts --compile --outfile ../../dist/algochains-win-x64.exe --target bun-windows-x64",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "chalk": "^5.0.0",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "enquirer": "^2.4.1",
    "eventsource": "^4.1.0",
    "hono": "^4.12.26",
    "ink": "^7.0.6",
    "ink-spinner": "^5.0.0",
    "keytar": "^7.9.0",
    "node-cron": "^4.2.1",
    "ora": "^9.4.0",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "bun-types": "latest",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
